# Copy to .env and fill in. All env vars are prefixed TRAIN_ to avoid
# collision with blackheart-ingest (INGEST_*) and the trading JVM.

TRAIN_DB_HOST=localhost
TRAIN_DB_PORT=5432
TRAIN_DB_NAME=trading_db
TRAIN_DB_USER=blackheart_research
TRAIN_DB_PASSWORD=research_dev_pass

# Where artifacts land. Content-addressed: artifacts/<sha256[:2]>/<sha256>.pkl.
TRAIN_ARTIFACT_DIR=C:/Project/blackheart-train/artifacts

TRAIN_LOG_LEVEL=INFO
